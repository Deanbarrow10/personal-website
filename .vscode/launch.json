{
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Debug Astro",
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/astro",
        "runtimeArgs": ["dev"],
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder}/dist/**/*.js"],
        "cwd": "${workspaceFolder}",
        "env": {
          "NODE_ENV": "development"
        }
      }
    ]
  }