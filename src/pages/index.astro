---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import ClientsSection from "@components/sections/landing/ClientsSection.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import PricingSection from "@components/sections/pricing/PricingSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import heroImage from "@images/dean-profile.avif";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import pricing from "@data/pricing.json";
import featureImage from "@images/features-image.avif";
import construction from "@images/mental-health.avif";
import tools from "@images/stanford.avif";
import dashboard from "@images/coding.avif";


---

<MainLayout>
  <!-- <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Contact Dean for Tutoring"
    url="https://www.wyzant.com/Tutors/CollegeTutorDean"
  /> -->

  <HeroSection
    title=`Dean Barrow's Personal <span
        class="text-yellow-500 dark:text-yellow-400">Website</span>`
    subTitle="Stanford CS student exploring how to make AI feel less artifical and more like a helpful companion."
    primaryBtn="Projects"
    primaryBtnURL="/products"
    secondaryBtn="Learn More"
    secondaryBtnURL="/services"
    src={heroImage}
    alt="Dean Barrow's profile picture"
  />

  <ClientsSection
    title="Experience from Top Programs"
  />


  <FeaturesNavs
    title=`Here's a bit about my <span class="text-yellow-500 dark:text-yellow-400">journey</span>.`
    tabs={[
      {
        heading: "Early Beginnings & Education",
        content:
          "I grew up outside Chicago and was always drawn to software and mathematics—building websites, solving math puzzles, and understanding the logic behind how programs work. That curiosity led me to the Illinois Mathematics and Science Academy, where I deepened my programming skills and realized I could build the applications I was imagining. Now I'm at Stanford studying CS and exploring how to improve the connection between humans and AI, particularly making AI more integrated into our daily health routines.",
        svg: "tools",
        src: tools,
        alt: "Stanford Campus Photo",
        first: true,
      },
      {
        heading: "Tech Passion & Skills",
        content:
          "I've built several AI applications and spent time fine-tuning models to understand how they work. What excites me most is using technology to provide support for people who need it. There's something powerful about building systems that can actually help someone when they're struggling or looking for resources.",
        svg: "dashboard",
        src: dashboard,
        alt: "Coding workspace",
        second: true,
      },
      {
        heading: "From Nonprofit to Tech",
        content:
          "In high school, I started an educational nonprofit, which taught me that having good intentions isn't enough—you need to build things that work. That experience got me thinking about how technology could create real impact. Now I'm developing an iOS app for wellness support because there's a gap between what people need and what's currently available.",
        svg: "house",
        src: construction,
        alt: "Mental Health Support",
      },
    ]}
  />



  <FAQ title="Frequently<br />asked questions" faqs={faqs} />


</MainLayout>
